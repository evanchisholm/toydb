{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Work order 422 validation error response",
  "type": "object",
  "properties": {
    "message": {
      "type": "string",
      "description": "Top-level error message",
      "examples": ["The given data was invalid."]
    },
    "errors": {
      "type": "object",
      "description": "Field-wise validation error messages keyed by input field name",
      "additionalProperties": {
        "type": "array",
        "items": { "type": "string" }
      }
    }
  },
  "required": ["message", "errors"],
  "examples": [
    {
      "message": "The given data was invalid.",
      "errors": {
        "title": ["The title field is required."],
        "description": ["The description field is required."],
        "due_date": ["The due date is not a valid date."]
      }
    },
    {
      "message": "The given data was invalid.",
      "errors": {
        "status": ["The selected status is invalid."],
        "priority": ["The selected priority is invalid."]
      }
    }
  ]
}

